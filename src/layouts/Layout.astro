---
import ThemeToggle from '../components/ThemeToggle.astro';

const {
  title = 'six_moon 的博客',
  description = '欢迎来到我的博客',
  mainClass = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/images/blog/favicon.svg" />
    <script is:inline>
      (() => {
        const storageKey = 'six-moon-theme';
        const savedTheme = localStorage.getItem(storageKey);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = savedTheme || (prefersDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <nav class="navbar">
      <div class="nav-left">
        <ThemeToggle />
        <a href="/" class="nav-brand">six_moon 的博客</a>
      </div>
      <div class="nav-links">
        <a href="/blog">博客</a>
        <a href="/about">关于</a>
      </div>
    </nav>
    <main class={mainClass || undefined}>
      <slot />
    </main>
    <footer>
      <p>© 2026 six_moon. Built with Astro.</p>
    </footer>
    <script is:inline>
      (() => {
        const storageKey = 'six-moon-theme';
        const button = document.querySelector('[data-theme-toggle]');

        function applyTheme(theme) {
          document.documentElement.dataset.theme = theme;
          localStorage.setItem(storageKey, theme);
          button?.setAttribute('aria-pressed', String(theme === 'dark'));
        }

        button?.addEventListener('click', () => {
          const currentTheme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
          applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
        });

        applyTheme(document.documentElement.dataset.theme || 'light');
      })();
    </script>
  </body>
</html>

<style>
  :global(:root) {
    color-scheme: light;
    --page-bg: #ffffff;
    --text-primary: #111827;
    --text-secondary: #4b5563;
    --text-muted: #6b7280;
    --border-color: #e5e7eb;
    --surface-bg: #ffffff;
    --surface-soft: #f3f4f6;
    --surface-hover: #eef2ff;
    --font-body: "Segoe UI", "Microsoft YaHei", "微软雅黑", system-ui, -apple-system,
      BlinkMacSystemFont, Arial, sans-serif;
    --font-code: Consolas, "Microsoft YaHei UI", "Microsoft YaHei", "微软雅黑",
      "Courier New", monospace;
    --accent: #667eea;
    --accent-strong: #4338ca;
    --accent-soft: #e0e7ff;
    --code-bg: #f6f8fa;
    --code-text: #24292f;
    --code-block-bg: #111827;
    --code-block-text: #e5e7eb;
    --table-header-bg: #f8fafc;
    --table-row-alt-bg: #fbfdff;
    --image-border: rgba(15, 23, 42, 0.12);
    --image-shadow: 0 18px 45px rgba(15, 23, 42, 0.12);
    --nav-bg: #1a1a2e;
    --nav-text: #ffffff;
    --nav-border: rgba(255, 255, 255, 0.24);
    --nav-button-bg: rgba(255, 255, 255, 0.08);
    --nav-button-hover-bg: rgba(255, 255, 255, 0.16);
    --shadow-soft: 0 4px 14px rgba(31, 41, 55, 0.08);
  }

  :global(html[data-theme='dark']) {
    color-scheme: dark;
    --page-bg: #111827;
    --text-primary: #f9fafb;
    --text-secondary: #d1d5db;
    --text-muted: #9ca3af;
    --border-color: #374151;
    --surface-bg: #1f2937;
    --surface-soft: #273449;
    --surface-hover: #312e81;
    --accent: #a5b4fc;
    --accent-strong: #c7d2fe;
    --accent-soft: #312e81;
    --code-bg: #273449;
    --code-text: #e5e7eb;
    --code-block-bg: #020617;
    --code-block-text: #e2e8f0;
    --table-header-bg: #273449;
    --table-row-alt-bg: rgba(255, 255, 255, 0.03);
    --image-border: rgba(148, 163, 184, 0.24);
    --image-shadow: 0 18px 45px rgba(0, 0, 0, 0.35);
    --nav-bg: #030712;
    --nav-text: #f9fafb;
    --nav-border: rgba(255, 255, 255, 0.18);
    --nav-button-bg: rgba(255, 255, 255, 0.08);
    --nav-button-hover-bg: rgba(255, 255, 255, 0.16);
    --shadow-soft: 0 4px 18px rgba(0, 0, 0, 0.28);
  }

  :global(html) {
    background: var(--page-bg);
    font-family: var(--font-body);
    line-height: 1.75;
    -webkit-text-size-adjust: 100%;
  }

  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    background: var(--page-bg);
    color: var(--text-primary);
    font-size: 16px;
    line-height: 1.75;
    transition:
      background-color 0.2s,
      color 0.2s;
  }

  :global(pre),
  :global(code),
  :global(kbd),
  :global(samp),
  :global(.astro-code),
  :global(.astro-code code),
  :global(.astro-code span),
  :global(.expressive-code),
  :global(.expressive-code pre),
  :global(.expressive-code code),
  :global(.expressive-code span),
  :global(pre code) {
    font-family: var(--font-code);
  }

  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background: var(--nav-bg);
    color: var(--nav-text);
  }
  .nav-left {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .nav-brand {
    font-size: 1.25rem;
    font-weight: bold;
    color: var(--nav-text);
    text-decoration: none;
  }
  .nav-links a {
    color: var(--nav-text);
    text-decoration: none;
    margin-left: 1.5rem;
  }
  main {
    max-width: 800px;
    margin: 2rem auto;
    padding: 0 1rem;
  }
  main.article-main {
    max-width: min(1360px, calc(100vw - 2rem));
  }
  footer {
    text-align: center;
    padding: 2rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .navbar {
      align-items: flex-start;
      flex-direction: column;
      gap: 1rem;
    }

    .nav-links a {
      margin-left: 0;
      margin-right: 1.25rem;
    }
  }
</style>
