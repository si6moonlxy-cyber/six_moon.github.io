---
import '../styles/theme.css';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import ThemeScript from '../components/ThemeScript.astro';

const {
  title = 'six_moon 的博客',
  description = '欢迎来到我的博客',
  mainClass = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/images/blog/favicon.svg" />
    <script is:inline>
      (() => {
        const k = 'six-moon-theme';
        const t = localStorage.getItem(k) || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>
  <body>
    <NavBar />
    <main class={mainClass || undefined}>
      <slot />
    </main>
    <Footer />
    <ThemeScript />
  </body>
</html>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }
  main {
    max-width: 800px;
    margin: 2rem auto;
    padding: 0 1rem;
  }
  main.article-main {
    max-width: min(1360px, calc(100vw - 2rem));
  }
</style>
