---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import TagFilter from '../../components/TagFilter.astro';
import { BLOG_TAGS, getPublishedPosts, postHasTag, type BlogPost } from '../../lib/posts';
import { TAG_SLUGS, type BlogTag } from '../../lib/tags';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return BLOG_TAGS.flatMap((tag) => {
    const filteredPosts = posts.filter((post) => postHasTag(post, tag));

    return [TAG_SLUGS[tag], tag].map((routeTag) => ({
      params: { tag: routeTag },
      props: {
        tag,
        posts: filteredPosts,
      },
    }));
  });
}

const { tag, posts } = Astro.props as { tag: BlogTag; posts: BlogPost[] };
---

<Layout title={`${tag} - six_moon`} description={`浏览 ${tag} 标签下的文章`}>
  <h1>{tag}</h1>
  <TagFilter activeTag={tag} />

  {
    posts.length > 0 ? (
      <div class="post-list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <p class="empty">这个标签下还没有文章。</p>
    )
  }
</Layout>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .empty {
    color: var(--text-muted);
  }
</style>
