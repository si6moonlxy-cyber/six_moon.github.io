---
import Layout from '../../layouts/Layout.astro';
import { render } from 'astro:content';
import {
  getCompactPostSlug,
  getLegacyPostSlug,
  getSourcePostSlug,
  getPublishedPosts,
} from '../../lib/posts';
import { getTagUrl } from '../../lib/tags';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.flatMap((post) => {
    const canonicalSlug = getLegacyPostSlug(post);
    const sourceSlug = getSourcePostSlug(post);
    const compactSlug = getCompactPostSlug(post);
    const slugs = Array.from(new Set([canonicalSlug, sourceSlug, compactSlug]));

    return slugs.map((slug) => ({
      params: { slug },
      props: { post },
    }));
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="blog-post">
    <header>
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('zh-CN')}
        </time>
        {post.data.updatedDate && (
          <span class="updated">
            更新于 {post.data.updatedDate.toLocaleDateString('zh-CN')}
          </span>
        )}
      </div>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag) => (
            <a class="tag" href={getTagUrl(tag)}>#{tag}</a>
          ))}
        </div>
      )}
    </header>
    
    <div class="prose">
      <Content />
    </div>
    
    <footer>
      <a href="/blog" class="back-link">← 返回博客列表</a>
    </footer>
  </article>
</Layout>

<style>
  .blog-post {
    max-width: 800px;
    margin: 0 auto;
  }
  header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border-color);
  }
  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .post-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  .updated {
    color: var(--text-muted);
  }
  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag {
    background: var(--surface-soft);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
  }
  .tag:hover {
    background: var(--surface-hover);
    color: var(--accent-strong);
  }
  .prose {
    color: var(--text-primary);
    font-size: 1.0625rem;
    line-height: 1.85;
    overflow-wrap: break-word;
  }
  .prose h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .prose h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .prose p {
    margin-bottom: 1.5rem;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.5rem;
  }
  .prose :global(li) {
    margin-bottom: 0.45rem;
  }
  .prose code {
    background: var(--code-bg);
    color: var(--code-text);
    border: 1px solid var(--border-color);
    padding: 0.12rem 0.35rem;
    border-radius: 0.35rem;
    font-family: var(--font-code);
    font-size: 0.92em;
    white-space: break-spaces;
  }
  .prose pre {
    background: var(--code-block-bg);
    color: var(--code-block-text);
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--border-color);
    border-radius: 0.6rem;
    overflow-x: auto;
    max-width: 100%;
    margin: 0 0 1.5rem;
    line-height: 1.7;
    tab-size: 2;
    box-shadow: var(--shadow-soft);
    -webkit-overflow-scrolling: touch;
  }
  .prose pre code {
    background: transparent;
    border: 0;
    padding: 0;
    color: inherit;
    font-family: var(--font-code);
    font-size: 0.94rem;
    line-height: inherit;
    white-space: pre;
  }
  .prose img {
    max-width: 100%;
    border-radius: 0.5rem;
  }
  .prose :global(table) {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    border-spacing: 0;
    margin: 1.75rem 0;
    font-size: 0.96rem;
    line-height: 1.6;
    -webkit-overflow-scrolling: touch;
  }
  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--border-color);
    padding: 0.7rem 0.9rem;
    vertical-align: top;
    min-width: 7.5rem;
  }
  .prose :global(th) {
    background: var(--table-header-bg);
    color: var(--text-primary);
    font-weight: 700;
    text-align: left;
  }
  .prose :global(tr:nth-child(even) td) {
    background: var(--table-row-alt-bg);
  }
  .prose a {
    color: var(--accent-strong);
    font-weight: 500;
    text-decoration-line: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
    transition:
      color 0.2s,
      text-decoration-color 0.2s,
      background-color 0.2s;
  }
  .prose a:hover {
    color: var(--accent);
    background: var(--accent-soft);
    text-decoration-color: currentColor;
  }
  .prose blockquote {
    border-left: 4px solid var(--accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
  }
  footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 2px solid var(--border-color);
  }
  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .back-link:hover {
    text-decoration: underline;
  }
</style>
