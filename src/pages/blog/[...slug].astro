---
import '../../styles/prose.css';
import FloatingToc from '../../components/FloatingToc.astro';
import Layout from '../../layouts/Layout.astro';
import { render } from 'astro:content';
import {
  getCompactPostSlug,
  getLegacyPostSlug,
  getSourcePostSlug,
  getPublishedPosts,
} from '../../lib/posts';
import { getTagUrl } from '../../lib/tags';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.flatMap((post) => {
    const canonicalSlug = getLegacyPostSlug(post);
    const sourceSlug = getSourcePostSlug(post);
    const compactSlug = getCompactPostSlug(post);
    const slugs = Array.from(new Set([canonicalSlug, sourceSlug, compactSlug]));

    return slugs.map((slug) => ({
      params: { slug },
      props: { post },
    }));
  });
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<Layout title={post.data.title} description={post.data.description} mainClass="article-main">
  <FloatingToc headings={headings} />

  <div class="article-shell article-shell--without-toc">
    <article class="blog-post">
      <header>
        <h1>{post.data.title}</h1>
        <div class="post-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('zh-CN')}
          </time>
          {post.data.updatedDate && (
            <span class="updated">
              更新于 {post.data.updatedDate.toLocaleDateString('zh-CN')}
            </span>
          )}
        </div>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="tags">
            {post.data.tags.map((tag) => (
              <a class="tag" href={getTagUrl(tag)}>#{tag}</a>
            ))}
          </div>
        )}
      </header>

      <div class="prose">
        <Content />
      </div>

      <hr class="article-divider" />
      <p class="article-signature">Written By Six_moon</p>
    </article>
  </div>
</Layout>

<style>
  .article-shell {
    display: block;
    max-width: 960px;
    margin: 0 auto;
  }

  .blog-post {
    width: 100%;
    min-width: 0;
    max-width: 960px;
    margin: 0 auto;
  }

  header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border-color);
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    color: var(--text-muted);
    font-size: 0.6825rem;
    margin-bottom: 1rem;
  }

  .updated {
    color: var(--text-muted);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--surface-soft);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
  }

  .tag:hover {
    background: var(--surface-hover);
    color: var(--accent-strong);
  }

  .article-divider {
    margin: 2.5rem 0 0.8rem;
    border: 0;
    border-top: 1px solid var(--border-color);
  }

  .article-signature {
    margin: 0;
    text-align: right;
    font-family: var(--font-code);
    font-weight: 700;
    font-style: italic;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
</style>
