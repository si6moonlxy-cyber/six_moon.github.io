  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--nav-border);
    border-radius: 9999px;
    background: var(--nav-button-bg);
    color: var(--nav-text);
    cursor: pointer;
    transition:
      background-color 0.2s,
      border-color 0.2s,
      color 0.2s,
      transform 0.2s;
  }

  .theme-toggle:hover {
    background: var(--nav-button-hover-bg);
    transform: translateY(-1px);
  }

  .theme-toggle__icon {
    width: 1.1rem;
    height: 1.1rem;
    fill: currentColor;
  }

  :global(html[data-theme='light']) .theme-toggle__icon--sun,
  :global(html[data-theme='dark']) .theme-toggle__icon--moon {
    display: none;
  }
</style>
