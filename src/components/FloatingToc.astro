---
type TocHeading = { depth: number; slug: string; text: string };
type TocChild = TocHeading & { children: TocHeading[] };
type TocSection = TocHeading & { children: TocChild[] };

const { headings = [] } = Astro.props as { headings?: TocHeading[] };
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
const tocSections: TocSection[] = [];

for (const heading of tocHeadings) {
  if (heading.depth === 2 || tocSections.length === 0) {
    tocSections.push({ ...heading, depth: 2, children: [] });
    continue;
  }
  const section = tocSections[tocSections.length - 1];
  if (heading.depth === 3 || section.children.length === 0) {
    section.children.push({ ...heading, depth: 3, children: [] });
    continue;
  }
  section.children[section.children.length - 1].children.push(heading);
}

const hasToc = tocSections.length > 0;
---

{hasToc && (
  <>
    <div class="toc-overlay-mask" data-toc-mask aria-hidden="true"></div>
    <aside class="toc-overlay-panel" data-toc-panel aria-hidden="true" aria-label="文章大纲">
      <div class="toc-overlay-header">
        <span class="toc-overlay-title">大纲</span>
        <button class="toc-overlay-close" type="button" data-toc-close aria-label="关闭大纲">&times;</button>
      </div>
      <nav class="toc-overlay-tree">
        <ol class="toc-sections">
          {tocSections.map((section) => (
            <li class="toc-section">
              <a class="toc-link toc-link--h2" href={`#${section.slug}`} data-toc-link data-toc-depth="2">
                {section.text}
              </a>
              {section.children.length > 0 && (
                <ol class="toc-children">
                  {section.children.map((child) => (
                    <li>
                      <a class="toc-link toc-link--h3" href={`#${child.slug}`} data-toc-link data-toc-depth="3">
                        {child.text}
                      </a>
                      {child.children.length > 0 && (
                        <ol class="toc-grandchildren">
                          {child.children.map((gc) => (
                            <li>
                              <a class="toc-link toc-link--h4" href={`#${gc.slug}`} data-toc-link data-toc-depth="4">
                                {gc.text}
                              </a>
                            </li>
                          ))}
                        </ol>
                      )}
                    </li>
                  ))}
                </ol>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </aside>
    <script is:inline>
  (() => {
    var mask = document.querySelector('[data-toc-mask]');
    var panel = document.querySelector('[data-toc-panel]');
    var toggle = document.querySelector('[data-toc-toggle]');
    var close = document.querySelector('[data-toc-close]');
    var links = Array.from(document.querySelectorAll('[data-toc-link]'));
    var dot = document.querySelector('[data-toc-dot]');

    if (!mask || !panel || !toggle) return;

    function isOpen() {
      return toggle.getAttribute('aria-expanded') === 'true';
    }

    function open() {
      mask.setAttribute('aria-hidden', 'false');
      panel.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', '关闭大纲');
      if (close) close.focus();
    }

    function closeToc() {
      mask.setAttribute('aria-hidden', 'true');
      panel.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', '打开大纲');
      toggle.focus();
    }

    toggle.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      if (isOpen()) closeToc();
      else open();
    });

    mask.addEventListener('click', function (e) {
      e.preventDefault();
      closeToc();
    });

    if (close) {
      close.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        closeToc();
      });
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen()) closeToc();
    });

    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', function () { closeToc(); });
    }

    // Show thumbnail
    toggle.removeAttribute('hidden');

    // --- IntersectionObserver: position tracking ---
    var headingEls = [];
    for (var i = 0; i < links.length; i++) {
      var href = links[i].getAttribute('href') || '';
      var id = href.indexOf('#') === 0 ? href.slice(1) : '';
      var el = id ? document.getElementById(id) : null;
      if (el) headingEls.push({ el: el, link: links[i] });
    }

    if (headingEls.length === 0) return;

    var visible = [];
    var observer = new IntersectionObserver(
      function (entries) {
        for (var i = 0; i < entries.length; i++) {
          var entry = entries[i];
          var found = null;
          for (var j = 0; j < headingEls.length; j++) {
            if (headingEls[j].el === entry.target) { found = headingEls[j]; break; }
          }
          if (!found) continue;
          var idx = visible.indexOf(found);
          if (entry.isIntersecting && idx === -1) visible.push(found);
          else if (!entry.isIntersecting && idx !== -1) visible.splice(idx, 1);
        }

        for (var i = 0; i < headingEls.length; i++) {
          headingEls[i].link.removeAttribute('aria-current');
        }

        visible.sort(function (a, b) { return a.el.offsetTop - b.el.offsetTop; });
        var active = visible[0];

        if (active) {
          active.link.setAttribute('aria-current', 'true');
          if (dot) dot.setAttribute('data-active', '');
        } else {
          if (dot) dot.removeAttribute('data-active');
        }
      },
      { rootMargin: '-15% 0px -70% 0px', threshold: 0 }
    );

    for (var i = 0; i < headingEls.length; i++) observer.observe(headingEls[i].el);

    // Initial active
    for (var i = headingEls.length - 1; i >= 0; i--) {
      if (headingEls[i].el.offsetTop <= window.scrollY + 140) {
        headingEls[i].link.setAttribute('aria-current', 'true');
        if (dot) dot.setAttribute('data-active', '');
        break;
      }
    }
  })();
</script>
  </>
)}

<style>
  .toc-overlay-mask {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.35);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .toc-overlay-mask[aria-hidden='false'] {
    opacity: 1;
    pointer-events: auto;
  }

  .toc-overlay-panel {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 201;
    width: min(20rem, 85vw);
    height: 100vh;
    background: var(--surface-bg);
    border-right: 1px solid var(--border-color);
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }

  .toc-overlay-panel[aria-hidden='false'] {
    transform: translateX(0);
  }

  .toc-overlay-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3rem;
    padding: 0 1rem;
    border-bottom: 1px solid var(--border-color);
    flex-shrink: 0;
  }

  .toc-overlay-title {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .toc-overlay-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 0;
    border-radius: 0.4rem;
    background: transparent;
    color: var(--text-muted);
    font-size: 1.3rem;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
  }

  .toc-overlay-close:hover {
    background: var(--surface-hover);
    color: var(--text-primary);
  }

  .toc-overlay-tree {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem;
    scrollbar-width: thin;
  }

  .toc-sections,
  .toc-children,
  .toc-grandchildren {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .toc-sections { display: grid; gap: 0.08rem; }
  .toc-children { display: grid; gap: 0.04rem; padding: 0.08rem 0 0.15rem; }
  .toc-grandchildren { display: grid; gap: 0.03rem; padding-bottom: 0.08rem; }

  .toc-link {
    display: block;
    min-width: 0;
    border-left: 2px solid transparent;
    border-radius: 0.35rem;
    color: var(--text-muted);
    text-decoration: none;
    line-height: 1.45;
    overflow-wrap: anywhere;
    transition: background-color 0.18s, border-color 0.18s, color 0.18s;
  }

  .toc-link:hover {
    background: var(--surface-hover);
    color: var(--accent-strong);
  }

  .toc-link[aria-current='true'] {
    background: var(--surface-hover);
    border-left-color: var(--accent);
    color: var(--accent-strong);
  }

  .toc-link--h2 {
    padding: 0.36rem 0.5rem;
    color: var(--text-primary);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .toc-link--h3 {
    margin-left: 1.6rem;
    padding: 0.3rem 0.45rem 0.3rem 0.75rem;
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 550;
  }

  .toc-link--h4 {
    margin-left: 2.7rem;
    padding: 0.26rem 0.45rem 0.26rem 0.8rem;
    color: var(--text-muted);
    font-size: 0.76rem;
    font-weight: 450;
  }
</style>
